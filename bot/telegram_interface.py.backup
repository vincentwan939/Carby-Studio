    async def handle_retry(self, query, entity_type: str, entity_id: str):
        """Retry failed gate or stage with loading indicator."""
        await query.answer("🔄 Retrying...")
        loading_text = get_loading_message("retry", "initial", detail=f"Entity: {entity_id}")
        await query.edit_message_text(
            loading_text,
            parse_mode="Markdown"
        )
        
        # Perform operation based on entity type
        if entity_type == "sprint":
            # For sprints, retry the current gate
            summary = self.state_manager.get_sprint_summary(entity_id)
            current_gate = summary.get("current_gate", 1) if summary else 1
            result = self.bot.cli_executor.sprint_gate(entity_id, current_gate, retry=True)
        else:
            result = self.bot.retry_stage(entity_id)
        
        if result.success:
            success_text = get_loading_message(
                "retry",
                "success",
                detail=f"Entity: *{entity_id}*\n\n```{result.stdout}```"
            )
            await query.edit_message_text(
                success_text,
                parse_mode="Markdown"
            )
        else:
            error_text = get_loading_message(
                "retry",
                "error",
                detail=f"Entity: *{entity_id}*\n\n```{result.stderr}```"
            )
            await query.edit_message_text(
                error_text,
                parse_mode="Markdown"
            )
            
    async def handle_skip(self, query, entity_type: str, entity_id: str):
        """Skip current gate or stage with loading indicator."""
        await query.answer("⏭️ Skipping...")
        loading_text = get_loading_message("skip", "initial", detail=f"Entity: {entity_id}")
        await query.edit_message_text(
            loading_text,
            parse_mode="Markdown"
        )
        
        # Perform operation based on entity type
        if entity_type == "sprint":
            # For sprints, skip the current gate
            summary = self.state_manager.get_sprint_summary(entity_id)
            current_gate = summary.get("current_gate", 1) if summary else 1
            result = self.bot.cli_executor.sprint_gate(entity_id, current_gate, force=True)
        else:
            result = self.bot.skip_stage(entity_id)
        
        if result.success:
            success_text = get_loading_message(
                "skip",
                "success",
                detail=f"Entity: *{entity_id}*\n\n```{result.stdout}```"
            )
            await query.edit_message_text(
                success_text,
                parse_mode="Markdown"
            )
        else:
            error_text = get_loading_message(
                "skip",
                "error",
                detail=f"Entity: *{entity_id}*\n\n```{result.stderr}```"
            )
            await query.edit_message_text(
                error_text,
                parse_mode="Markdown"
            )
            
    async def handle_stop(self, query, entity_type: str, entity_id: str):
        """Stop current agent with loading indicator."""
        await query.answer("🛑 Stopping...")
        loading_text = get_loading_message("stop", "initial", detail=f"Entity: {entity_id}")
        await query.edit_message_text(
            loading_text,
            parse_mode="Markdown"
        )
        
        # Perform operation based on entity type
        if entity_type == "sprint":
            result = self.bot.cli_executor.sprint_pause(entity_id)
        else:
            success, message = self.bot.stop_agent(entity_id)
            result = type('obj', (object,), {'success': success, 'stdout': message, 'stderr': ''})()
        
        if hasattr(result, 'success') and result.success:
            success_text = get_loading_message(
                "stop",
                "success",
                detail=f"Entity: *{entity_id}*\n\n{getattr(result, 'stdout', '')}"
            )
            await query.edit_message_text(
                success_text,
                parse_mode="Markdown",
                reply_markup=InlineKeyboardMarkup([[
                    InlineKeyboardButton("← Back", callback_data=f"view:{entity_type}:{entity_id}")
                ]])
            )
        else:
            error_text = get_loading_message(
                "stop",
                "error",
                detail=f"Entity: *{entity_id}*\n\n{getattr(result, 'stderr', getattr(result, 'stdout', 'Unknown error'))}"
            )
            await query.edit_message_text(
                error_text,
                reply_markup=InlineKeyboardMarkup([[
                    InlineKeyboardButton("← Back", callback_data=f"view:{entity_type}:{entity_id}")
                ]])
            )
            
    async def handle_logs(self, query, entity_type: str, entity_id: str):
        """View entity logs with loading indicator."""
        await query.answer("📋 Fetching logs...")
        loading_text = get_loading_message("logs", "initial", detail=f"Entity: {entity_id}")
        await query.edit_message_text(
            loading_text,
            parse_mode="Markdown"
        )
        
        # Perform operation based on entity type
        if entity_type == "sprint":
            result = self.bot.cli_executor.sprint_phase_status(entity_id)
        else:
            result = self.bot.cli_executor.logs(entity_id)
        
        if result.success:
            # Truncate if too long
            logs = result.stdout[:3000] if len(result.stdout) > 3000 else result.stdout
            success_text = get_loading_message(
                "logs",
                "success",
                detail=f"*{entity_id} Logs*\n\n```\n{logs}\n```"
            )
            await query.edit_message_text(
                success_text,
                parse_mode="Markdown"
            )
        else:
            error_text = get_loading_message(
                "logs",
                "error",
                detail=f"Entity: *{entity_id}*\n\n```{result.stderr}```"
            )
            await query.edit_message_text(
                error_text,
                parse_mode="Markdown"
            )
            
    async def handle_back_to_projects(self, query):
        """Return to projects list - show both projects and sprints."""
        projects = self.state_manager.list_projects()
        sprints = self.state_manager.list_sprints()
        
        if not projects and not sprints:
            await query.edit_message_text(
                "📋 No projects or sprints found.\n\nCreate one with: `carby-sprint init <name>`",
                parse_mode="Markdown"
            )
            return
        
        # Combine and sort entities
        entities = []
        
        # Add projects
        for project_id in projects:
            summary = self.state_manager.get_project_summary(project_id)
            if not summary:
                continue
            
            project_status = summary.get("status", "")
            current_status = summary.get("current_status", "")
            
            if project_status == "completed" or current_status == "completed":
                icon = "🟢"
            elif current_status == "in-progress":
                icon = "🟡"
            elif current_status == "failed":
                icon = "🔴"
            else:
                icon = "🔵"
            
            entities.append((project_id, icon, "project"))
        
        # Add sprints
        for sprint_id in sprints:
            summary = self.state_manager.get_sprint_summary(sprint_id)
            if not summary:
                continue
            
            sprint_status = summary.get("status", "")
            current_status = summary.get("current_status", "")
            
            if sprint_status in ["completed", "archived"]:
                icon = "✅"
            elif current_status == "in-progress":
                icon = "🔄"
            elif current_status == "failed":
                icon = "❌"
            elif current_status == "paused":
                icon = "⏸️"
            else:
                icon = "⬜"
            
            entities.append((sprint_id, icon, "sprint"))
        
        # Header text
        text = f"📋 Your Projects & Sprints ({len(entities)})\n\nTap an entity to view details:"
        
        # Build keyboard: 2 buttons per row
        keyboard = []
        for i in range(0, len(entities), 2):
            row = []
            # First button in row
            entity_id, icon, entity_type = entities[i]
            row.append(InlineKeyboardButton(f"{icon} {entity_id}", callback_data=f"view:{entity_type}:{entity_id}"))
            # Second button in row (if exists)
            if i + 1 < len(entities):
                entity_id2, icon2, entity_type2 = entities[i + 1]
                row.append(InlineKeyboardButton(f"{icon2} {entity_id2}", callback_data=f"view:{entity_type2}:{entity_id2}"))
            keyboard.append(row)
        
        # Add back to main menu button
        keyboard.append([InlineKeyboardButton("← Back to Main Menu", callback_data="back:main")])
        
        reply_markup = InlineKeyboardMarkup(keyboard) if keyboard else None
        await query.edit_message_text(text, reply_markup=reply_markup)
        
    async def handle_back_to_main(self, query):
        """Return to main menu - send new message with reply keyboard."""
        await query.answer()
        welcome_text = (
            "🤖 *Welcome to Carby Studio Bot!*\n\n"
            "Your AI-powered development assistant.\n\n"
            "*Quick Actions:*\n"
            "• 📋 Projects — View all projects and sprints\n"
            "• ⚙️ More — System status & help\n\n"
            "Tap a button below to get started! 👇"
        )
        # Delete the inline keyboard message and send a new one with reply keyboard
        await query.delete_message()
        await self.application.bot.send_message(
            chat_id=query.from_user.id,
            text=welcome_text,
            parse_mode="Markdown",
            reply_markup=MAIN_KEYBOARD
        )
        
    async def rename_start(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Start rename conversation."""
        query = update.callback_query
        await query.answer()
        
        parts = query.data.split(":")
        if len(parts) < 2:
            await query.edit_message_text("❌ Invalid callback data")
            return
        
        entity_id = parts[1]
        context.user_data['renaming_entity'] = entity_id
        
        await query.edit_message_text(
            f"✏️ *Rename {entity_id}*\n\n"
            f"Enter new entity name:",
            parse_mode="Markdown"
        )
        return RENAME_PROJECT
    
    async def rename_confirm(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Show rename confirmation dialog."""
        old_name = context.user_data.get('renaming_entity')
        new_name = update.message.text.strip()
        
        if not old_name:
            await update.message.reply_text("Error: No entity selected.", reply_markup=MAIN_KEYBOARD)
            return ConversationHandler.END
        
        # Validate new name format
        import re
        if not re.match(r'^[a-z0-9-]+$', new_name):
            await update.message.reply_text(
                "❌ *Invalid Entity Name*\n\n"
                "Names must contain only:\n"
                "• Lowercase letters (a-z)\n"
                "• Numbers (0-9)\n"
                "• Hyphens (-)\n\n"
                "Examples: my-entity, entity123, new-app",
                parse_mode="Markdown",
                reply_markup=MAIN_KEYBOARD
            )
            return ConversationHandler.END
        
        # Store new name for confirmation
        context.user_data['rename_new_name'] = new_name
        
        # Show confirmation dialog
        keyboard = InlineKeyboardMarkup([
            [InlineKeyboardButton("✅ Yes, Rename", callback_data=f"confirm_rename:{new_name}")],
            [InlineKeyboardButton("❌ Cancel", callback_data="cancel_rename")]
        ])
        
        await update.message.reply_text(
            f"⚠️ *Confirm Rename*\n\n"
            f"From: `{old_name}`\n"
            f"To: `{new_name}`\n\n"
            f"This cannot be undone.",
            parse_mode="Markdown",
            reply_markup=keyboard
        )
        return RENAME_CONFIRM
        
    async def rename_execute(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Execute rename with loading indicator."""
        query = update.callback_query
        await query.answer()
        
        data = query.data
        
        if data == "cancel_rename":
            await query.edit_message_text(
                "❌ Rename cancelled.",
                reply_markup=MAIN_KEYBOARD
            )
            return ConversationHandler.END
        
        # Extract new name from callback data
        if not data.startswith("confirm_rename:"):
            await query.edit_message_text(
                "Error: Invalid confirmation.",
                reply_markup=MAIN_KEYBOARD
            )
            return ConversationHandler.END
        
        new_name = data.split(":", 1)[1]
        old_name = context.user_data.get('renaming_entity')
        
        if not old_name:
            await query.edit_message_text(
                "Error: No entity selected.",
                reply_markup=MAIN_KEYBOARD
            )
            return ConversationHandler.END
        
        # Show loading
        loading_text = get_loading_message("rename", "initial", detail=f"From: {old_name}\nTo: {new_name}")
        await query.edit_message_text(
            loading_text,
            parse_mode="Markdown"
        )
        
        # Perform operation
        success, message = self.bot.rename_project(old_name, new_name)
        
        if success:
            success_text = get_loading_message(
                "rename",
                "success",
                detail=message
            )
            await query.edit_message_text(
                success_text,
                parse_mode="Markdown",
                reply_markup=MAIN_KEYBOARD
            )
        else:
            error_info = get_error_info("E3005", {"entity": old_name})
            error_text = format_error_message(error_info)
            await query.edit_message_text(
                error_text,
                parse_mode="Markdown",
                reply_markup=MAIN_KEYBOARD
            )
        
        return ConversationHandler.END
        
    async def delete_start(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Start delete conversation - show confirmation buttons."""
        query = update.callback_query
        await query.answer()
        
        parts = query.data.split(":")
        if len(parts) < 2:
            await query.edit_message_text("❌ Invalid callback data")
            return
        
        entity_id = parts[1]
        context.user_data['deleting_entity'] = entity_id
        
        # Get safety preview
        check = self.bot.safety_manager.check_delete(entity_id)
        preview = self.bot.safety_manager.format_delete_preview(entity_id, check.details or {})
        
        # Show confirmation with buttons
        keyboard = InlineKeyboardMarkup([
            [InlineKeyboardButton("✅ Yes, Delete", callback_data=f"confirm_delete:unknown:{entity_id}")],
            [InlineKeyboardButton("❌ Cancel", callback_data=f"view:unknown:{entity_id}")]
        ])
        
        await query.edit_message_text(
            f"{preview}\n\nAre you sure you want to delete this entity?",
            reply_markup=keyboard
        )
        return ConversationHandler.END
        
    async def delete_execute(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Execute delete - no longer used with button flow."""
        pass
        
    async def handle_confirm_delete(self, query, entity_type: str, entity_id: str):
        """Handle delete confirmation with loading indicator."""
        await query.answer("🗑️ Deleting...")
        loading_text = get_loading_message("delete", "initial", detail=f"Entity: {entity_id}")
        await query.edit_message_text(
            loading_text,
            parse_mode="Markdown"
        )
        
        # Perform operation
        success, message = self.bot.delete_project(entity_id, "DELETE")
        
        if success:
            success_text = get_loading_message(
                "delete",
                "success",
                detail=f"{message}\n\nReturning to projects..."
            )
            await query.edit_message_text(success_text)
            # Show projects list after short delay
            await self.handle_back_to_projects(query)
        else:
            error_text = get_loading_message(
                "delete",
                "error",
                detail=message
            )
            await query.edit_message_text(
                error_text,
                reply_markup=InlineKeyboardMarkup([[
                    InlineKeyboardButton("← Back", callback_data=f"view:{entity_type}:{entity_id}")
                ]])
            )
        
    async def handle_message(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Handle natural language messages with improved NLU."""
        text = update.message.text
        
        # Match intent using NLU
        intent, confidence = match_intent(text)
        
        logger.info(f"NLU: matched intent '{intent}' with confidence {confidence:.2f} for text: {text[:50]}")
        
        if intent == Intent.PROJECTS:
            await self.cmd_projects(update, context)
        
        elif intent == Intent.STATUS:
            await self.cmd_status(update, context)
        
        elif intent == Intent.CONTINUE:
            # Continue last active project/sprint
            projects = self.state_manager.list_projects()
            sprints = self.state_manager.list_sprints()
            
            all_entities = []
            # Add active projects
            for pid in projects:
                summary = self.state_manager.get_project_summary(pid)
                if summary and summary.get("current_status") == "in-progress":
                    all_entities.append(("project", pid))
            
            # Add active sprints
            for sid in sprints:
                summary = self.state_manager.get_sprint_summary(sid)
                if summary and summary.get("current_status") == "in-progress":
                    all_entities.append(("sprint", sid))
            
            if all_entities:
                # Use first active entity
                entity_type, entity_id = all_entities[0]
                
                if entity_type == "sprint":
                    summary = self.state_manager.get_sprint_summary(entity_id)
                    detail = f"Sprint {entity_id} - Status: {summary.get('status', 'Unknown')}"
                else:
                    summary = self.state_manager.get_project_summary(entity_id)
                    detail = f"Project {entity_id} - Status: {summary.get('status', 'Unknown')}"
                
                await update.message.reply_text(
                    f"🔄 *Resuming {entity_id}...*\n\n{detail}",
                    parse_mode="Markdown"
                )
                return
            
            await update.message.reply_text(
                "No active entities. Create one with: `carby-sprint init <name>`",
                parse_mode="Markdown",
                reply_markup=MAIN_KEYBOARD
            )
        
        elif intent == Intent.HELP:
            await self.cmd_help(update, context)
        
        elif intent == Intent.CREATE:
            # Create via bot removed - use CLI instead
            await update.message.reply_text(
                "➕ *Create New Sprint*\n\n"
                "Please use the CLI to create sprints:\n"
                "```\n"
                "carby-sprint init <sprint-name> --project <project-name> --goal 'Your goal'\n"
                "```",
                parse_mode="Markdown",
                reply_markup=MAIN_KEYBOARD
            )
        
        elif intent == Intent.STOP:
            # Stop the most recent active entity
            projects = self.state_manager.list_projects()
            sprints = self.state_manager.list_sprints()
            
            active_entity = None
            active_type = None
            
            # Check for active sprints first
            for sid in sprints:
                summary = self.state_manager.get_sprint_summary(sid)
                if summary and summary.get("current_status") == "in-progress":
                    active_entity = sid
                    active_type = "sprint"
                    break
            
            # If no active sprint, check for active project
            if not active_entity:
                for pid in projects:
                    summary = self.state_manager.get_project_summary(pid)
                    if summary and summary.get("current_status") == "in-progress":
                        active_entity = pid
                        active_type = "project"
                        break
            
            if active_entity:
                if active_type == "sprint":
                    result = self.bot.cli_executor.sprint_pause(active_entity)
                    if result.success:
                        await update.message.reply_text(
                            f"⏸️ *Sprint Paused*\n\nSprint {active_entity} has been paused.",
                            parse_mode="Markdown",
                            reply_markup=MAIN_KEYBOARD
                        )
                    else:
                        error_info = get_error_info("E3002", {"entity": active_entity})
                        await update.message.reply_text(
                            format_error_message(error_info),
                            parse_mode="Markdown",
                            reply_markup=MAIN_KEYBOARD
                        )
                else:
                    success, message = self.bot.stop_agent(active_entity)
                    if success:
                        await update.message.reply_text(
                            f"🛑 *Agent Stopped*\n\n{message}",
                            parse_mode="Markdown",
                            reply_markup=MAIN_KEYBOARD
                        )
                    else:
                        error_info = get_error_info("E3002", {"entity": active_entity})
                        await update.message.reply_text(
                            format_error_message(error_info),
                            parse_mode="Markdown",
                            reply_markup=MAIN_KEYBOARD
                        )
            else:
                await update.message.reply_text(
                    "No running agents to stop.",
                    reply_markup=MAIN_KEYBOARD
                )
        
        else:
            # Unknown intent - offer smart suggestions
            nlu = get_nlu_handler()
            suggestions = nlu.get_suggestions(text)
            suggestion_text = nlu.format_suggestions(suggestions)
            
            keyboard = InlineKeyboardMarkup([
                [InlineKeyboardButton("📋 View Projects", callback_data="back:projects")],
                [InlineKeyboardButton("📊 System Status", callback_data="status")],
                [InlineKeyboardButton("❓ Help", callback_data="help")]
            ])
            await update.message.reply_text(
                f"I'm not sure what you mean. {suggestion_text}",
                reply_markup=keyboard
            )


def main():
    """Main entry point."""
    handler = TelegramInterface()
    handler.run()


if __name__ == "__main__":
    main()