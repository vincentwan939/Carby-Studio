    async def cmd_cancel(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Cancel conversation."""
        await update.message.reply_text(
            "Cancelled.",
            reply_markup=MAIN_KEYBOARD
        )
        return ConversationHandler.END
        
    async def handle_callback(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """Handle button callbacks."""
        query = update.callback_query
        await query.answer()
        
        data = query.data
        parts = data.split(":")
        action = parts[0]
        
        if action == "view":
            if len(parts) >= 3:
                entity_type = parts[1]
                entity_id = parts[2]
                await self.handle_view(query, entity_type, entity_id)
            else:
                await query.edit_message_text("❌ Invalid callback data")
        elif action == "resume":
            if len(parts) >= 3:
                entity_type = parts[1]
                entity_id = parts[2]
                await self.handle_resume(query, entity_type, entity_id)
        elif action == "dispatch":
            if len(parts) >= 3:
                entity_type = parts[1]
                entity_id = parts[2]
                await self.handle_dispatch(query, entity_type, entity_id)
        elif action == "approve":
            if len(parts) >= 3:
                entity_type = parts[1]
                entity_id = parts[2]
                await self.handle_approve(query, entity_type, entity_id)
        elif action == "reject":
            if len(parts) >= 3:
                entity_type = parts[1]
                entity_id = parts[2]
                await self.handle_reject(query, entity_type, entity_id)
        elif action == "retry":
            if len(parts) >= 3:
                entity_type = parts[1]
                entity_id = parts[2]
                await self.handle_retry(query, entity_type, entity_id)
        elif action == "skip":
            if len(parts) >= 3:
                entity_type = parts[1]
                entity_id = parts[2]
                await self.handle_skip(query, entity_type, entity_id)
        elif action == "stop":
            if len(parts) >= 3:
                entity_type = parts[1]
                entity_id = parts[2]
                await self.handle_stop(query, entity_type, entity_id)
        elif action == "back":
            if parts[1] == "projects":
                await self.handle_back_to_projects(query)
            elif parts[1] == "main":
                await self.handle_back_to_main(query)
        elif action == "confirm_delete":
            if len(parts) >= 3:
                entity_type = parts[1]
                entity_id = parts[2]
                await self.handle_confirm_delete(query, entity_type, entity_id)
        elif action == "logs":
            if len(parts) >= 3:
                entity_type = parts[1]
                entity_id = parts[2]
                await self.handle_logs(query, entity_type, entity_id)
        elif action == "gate":
            if len(parts) >= 4:
                entity_type = parts[1]
                entity_id = parts[2]
                gate_number = int(parts[3])
                await self.handle_gate_action(query, entity_type, entity_id, gate_number)
        elif action == "pause":
            if len(parts) >= 3:
                entity_type = parts[1]
                entity_id = parts[2]
                await self.handle_pause(query, entity_type, entity_id)
        elif action == "resume-sprint":
            if len(parts) >= 3:
                entity_type = parts[1]
                entity_id = parts[2]
                await self.handle_resume_sprint(query, entity_type, entity_id)
        elif action == "cancel":
            if len(parts) >= 3:
                entity_type = parts[1]
                entity_id = parts[2]
                await self.handle_cancel(query, entity_type, entity_id)
        elif action == "archive":
            if len(parts) >= 3:
                entity_type = parts[1]
                entity_id = parts[2]
                await self.handle_archive(query, entity_type, entity_id)
        else:
            await query.edit_message_text("❌ Unknown action")
            
    def _gate_icon(self, status: str) -> str:
        """Get icon for gate status."""
        icons = {
            "pending": "⬜",
            "in-progress": "🔄",
            "completed": "✅",
            "approved": "✅",
            "failed": "❌",
            "skipped": "⏭️"
        }
        return icons.get(status, "⬜")
    
    def _phase_icon(self, status: str) -> str:
        """Get icon for phase status."""
        icons = {
            "pending": "◯",
            "in-progress": "◉",
            "completed": "✓",
            "approved": "✓",
            "failed": "✗",
            "skipped": "›"
        }
        return icons.get(status, "◯")
    
    def _build_sprint_actions(self, sprint: SprintState) -> InlineKeyboardMarkup:
        """Build action buttons based on sprint state."""
        buttons = []
        
        current_gate_idx = sprint.current_gate - 1
        
        if 0 <= current_gate_idx < len(sprint.gates):
            current_gate = sprint.gates[current_gate_idx]
            
            if current_gate.status == "pending":
                # Gate not started - show start button
                buttons.append([
                    InlineKeyboardButton("▶️ Start Gate", callback_data=f"gate:sprint:{sprint.sprint_id}:{sprint.current_gate}"),
                    InlineKeyboardButton("⏭️ Skip", callback_data=f"skip:sprint:{sprint.sprint_id}")
                ])
            elif current_gate.status == "in-progress":
                # Gate running - show pause and logs
                buttons.append([
                    InlineKeyboardButton("⏸️ Pause", callback_data=f"pause:sprint:{sprint.sprint_id}"),
                    InlineKeyboardButton("📋 Logs", callback_data=f"logs:sprint:{sprint.sprint_id}")
                ])
            elif current_gate.status in ["completed", "approved"]:
                # Gate done - show approve
                buttons.append([
                    InlineKeyboardButton("✅ Approve", callback_data=f"approve:sprint:{sprint.sprint_id}"),
                    InlineKeyboardButton("🔄 Retry", callback_data=f"retry:sprint:{sprint.sprint_id}")
                ])
            elif current_gate.status == "failed":
                # Gate failed - show retry/skip
                buttons.append([
                    InlineKeyboardButton("🔄 Retry", callback_data=f"retry:sprint:{sprint.sprint_id}"),
                    InlineKeyboardButton("⏭️ Skip", callback_data=f"skip:sprint:{sprint.sprint_id}"),
                    InlineKeyboardButton("📋 Logs", callback_data=f"logs:sprint:{sprint.sprint_id}")
                ])
        
        # Management buttons
        if sprint.status not in ["completed", "archived", "cancelled"]:
            buttons.append([
                InlineKeyboardButton("⏸️ Pause", callback_data=f"pause:sprint:{sprint.sprint_id}"),
                InlineKeyboardButton("❌ Cancel", callback_data=f"cancel:sprint:{sprint.sprint_id}")
            ])
        elif sprint.status in ["completed"]:
            buttons.append([
                InlineKeyboardButton("🗄️ Archive", callback_data=f"archive:sprint:{sprint.sprint_id}")
            ])
        
        return InlineKeyboardMarkup(buttons)
    
    async def handle_view(self, query, entity_type: str, entity_id: str):
        """View entity detail with improved status display."""
        if entity_type == "sprint":
            # Read full sprint state for detailed view
            full_state = self.state_manager.read_sprint(entity_id)
            summary = self.state_manager.get_sprint_summary(entity_id)
            
            if not full_state or not summary:
                await query.edit_message_text("❌ Sprint not found")
                return
            
            # Build detailed sprint view
            goal = full_state.get("goal", "No goal set")
            mode = full_state.get("mode", "sequential")
            sprint_status = full_state.get("status", "active")
            created = full_state.get("created_at", "Unknown")[:10]  # Just date part
            
            # Escape markdown characters
            def escape_md(text):
                return text.replace('\\', '\\\\').replace('_', '\\_').replace('*', '\\*').replace('[', '\\[').replace('`', '\\`')
            
            safe_entity_id = escape_md(entity_id)
            safe_goal = escape_md(goal)
            
            lines = [
                f"📋 *{safe_entity_id}*",
                f"🎯 {safe_goal}",
                f"📦 Project: {full_state.get('project', 'N/A')}",
                f"📅 Created: {created}",
                f"⚙️ Mode: {mode}",
                f"📊 Status: {sprint_status}",
                ""
            ]
            
            # Show gates and phases
            gates = full_state.get("gates", [])
            
            if gates:
                lines.append(" Gates & Phases:")
                for gate in gates:
                    gate_number = gate.get("gate_number", gate.get("number", 0))
                    gate_name = gate.get("name", f"Gate {gate_number}")
                    gate_status = gate.get("status", "pending")
                    
                    gate_icon = self._gate_icon(gate_status)
                    lines.append(f"{gate_icon} {gate_name} (Gate {gate_number})")
                    
                    # Show phases for this gate
                    phases = gate.get("phases", [])
                    for phase in phases:
                        phase_name = phase.get("name", phase.get("phase_id", "Unknown"))
                        phase_status = phase.get("status", "pending")
                        phase_icon = self._phase_icon(phase_status)
                        lines.append(f"   {phase_icon} {phase_name}")
            else:
                lines.append("⏳ No gates defined yet")
            
            lines.append("")
            
            # Overall status
            current_gate_num = full_state.get("current_gate", full_state.get("currentGate", 1))
            lines.append(f"📍 Current Gate: {current_gate_num}")
            
            # Add credential status
            try:
                import subprocess
                cred_result = subprocess.run(
                    ["python3", "-c", f"""
import sys
sys.path.insert(0, 'skills/carby-studio/lib')
from credentials_handler import CredentialsHandler
handler = CredentialsHandler()
status = handler.get_status('{entity_id}')
print(f"{{status['storage']}}|{{status['total']}}|{{status['verified']}}")
"""],
                    capture_output=True,
                    text=True,
                    timeout=10
                )
                if cred_result.returncode == 0:
                    parts = cred_result.stdout.strip().split('|')
                    if len(parts) >= 3:
                        storage, total, verified = parts[:3]
                        if int(total) > 0:
                            lines.append("")
                            lines.append(f"🔐 *Credentials:* {verified}/{total} verified")
                            lines.append(f"   Storage: {storage}")
            except Exception:
                pass
            
            text = "\n".join(lines)
            
            # Get sprint state object for action buttons
            sprint_state = self.state_manager.read_sprint_state(entity_id)
            if sprint_state:
                keyboard = self._build_sprint_actions(sprint_state)
            else:
                # Fallback buttons
                buttons = [
                    [InlineKeyboardButton("🔄 Resume", callback_data=f"resume:sprint:{entity_id}")],
                    [InlineKeyboardButton("✏️ Rename", callback_data=f"rename:{entity_id}"), 
                     InlineKeyboardButton("🗑️ Delete", callback_data=f"delete:{entity_id}")],
                    [InlineKeyboardButton("← Back to Projects", callback_data="back:projects")]
                ]
                keyboard = InlineKeyboardMarkup(buttons)
            
            await query.edit_message_text(text, parse_mode="Markdown", reply_markup=keyboard)
            
        elif entity_type == "project":
            # Handle legacy project view (existing code)
            full_state = self.state_manager.read_project(entity_id)
            summary = self.state_manager.get_project_summary(entity_id)
            
            if not full_state or not summary:
                await query.edit_message_text("❌ Project not found")
                return
            
            # Build detailed project view (same as original)
            goal = full_state.get("goal", "No goal set")
            mode = full_state.get("mode", "linear")
            project_status = full_state.get("status", "active")
            created = full_state.get("created", "Unknown")[:10]  # Just date part
            
            def escape_md(text):
                return text.replace('\\', '\\\\').replace('_', '\\_').replace('*', '\\*').replace('[', '\\[').replace('`', '\\`')
            
            safe_entity_id = escape_md(entity_id)
            safe_goal = escape_md(goal)
            
            lines = [
                f"📁 *{safe_entity_id}*",
                f"🎯 {safe_goal}",
                f"📅 Created: {created}",
                f"⚙️ Mode: {mode}",
                ""
            ]
            
            # Show stages/tasks
            stages = full_state.get("stages", {})
            pipeline = full_state.get("pipeline", [])
            
            if pipeline:
                lines.append("📊 *Stages:*")
                for stage in pipeline:
                    stage_info = stages.get(stage, {})
                    stage_status = stage_info.get("status", "pending")
                    agent = stage_info.get("agent", "unknown")
                    
                    # Status icons
                    icon = {
                        "done": "✅",
                        "in-progress": "🔄",
                        "failed": "❌",
                        "skipped": "⏭️",
                        "pending": "⬜"
                    }.get(stage_status, "⬜")
                    
                    lines.append(f"{icon} {stage} ({agent})")
            elif stages:
                # DAG mode - show all stages
                lines.append("📊 *Stages:*")
                for stage, stage_info in stages.items():
                    stage_status = stage_info.get("status", "pending")
                    agent = stage_info.get("agent", "unknown")
                    
                    icon = {
                        "done": "✅",
                        "in-progress": "🔄",
                        "failed": "❌",
                        "skipped": "⏭️",
                        "pending": "⬜"
                    }.get(stage_status, "⬜")
                    
                    lines.append(f"{icon} {stage} ({agent})")
            
            lines.append("")
            
            # Overall status
            if project_status == "completed":
                lines.append("✅ *Project Complete!*")
            elif project_status == "failed":
                lines.append("❌ *Project Failed*")
            else:
                current = full_state.get("currentStage") or full_state.get("current_stage")
                if current:
                    lines.append(f"▶️ *Current:* {current}")
                else:
                    # Find first pending
                    for stage in pipeline or list(stages.keys()):
                        stage_data = stages.get(stage, {})
                        if stage_data.get("status") == "pending":
                            lines.append(f"⏸️ *Ready:* {stage}")
                            break
            
            # Add credential status
            try:
                import subprocess
                cred_result = subprocess.run(
                    ["python3", "-c", f"""
import sys
sys.path.insert(0, 'skills/carby-studio/lib')
from credentials_handler import CredentialsHandler
handler = CredentialsHandler()
status = handler.get_status('{entity_id}')
print(f"{{status['storage']}}|{{status['total']}}|{{status['verified']}}")
"""],
                    capture_output=True,
                    text=True,
                    timeout=10
                )
                if cred_result.returncode == 0:
                    parts = cred_result.stdout.strip().split('|')
                    if len(parts) >= 3:
                        storage, total, verified = parts[:3]
                        if int(total) > 0:
                            lines.append("")
                            lines.append(f"🔐 *Credentials:* {verified}/{total} verified")
                            lines.append(f"   Storage: {storage}")
            except Exception:
                pass
            
            text = "\n".join(lines)
            
            # Build action buttons - Resume for ALL projects
            buttons = []
            
            # Primary action: Resume with Carby
            buttons.append([
                InlineKeyboardButton("🔄 Resume with Carby", callback_data=f"resume:project:{entity_id}")
            ])
            
            # Secondary actions based on status
            if project_status == "completed":
                buttons.append([InlineKeyboardButton("🗄️ Archive", callback_data=f"archive:project:{entity_id}")])
            elif project_status == "failed":
                buttons.append([
                    InlineKeyboardButton("🔄 Retry Stage", callback_data=f"retry:project:{entity_id}"),
                    InlineKeyboardButton("⏭️ Skip Stage", callback_data=f"skip:project:{entity_id}")
                ])
            elif project_status == "active":
                # Active project - check current stage status
                current_stage = summary.get("current_stage") or summary.get("currentStage")
                if current_stage and stages.get(current_stage, {}).get("status") == "in-progress":
                    buttons.append([
                        InlineKeyboardButton("🛑 Stop Agent", callback_data=f"stop:project:{entity_id}"),
                        InlineKeyboardButton("📋 View Logs", callback_data=f"logs:project:{entity_id}")
                    ])
            
            # Project management buttons
            buttons.append([
                InlineKeyboardButton("✏️ Rename", callback_data=f"rename:{entity_id}"),
                InlineKeyboardButton("🗑️ Delete", callback_data=f"delete:{entity_id}")
            ])
            
            buttons.append([InlineKeyboardButton("← Back to Projects", callback_data="back:projects")])
            
            keyboard = InlineKeyboardMarkup(buttons)
            await query.edit_message_text(text, parse_mode="Markdown", reply_markup=keyboard)
        else:
            await query.edit_message_text("❌ Unknown entity type")
    
    async def handle_dispatch(self, query, entity_type: str, entity_id: str):
        """Handle dispatch with loading indicator."""
        await query.answer("🚀 Dispatching...")
        loading_text = get_loading_message("dispatch", "initial", detail=f"Entity: {entity_id}")
        await query.edit_message_text(
            loading_text,
            parse_mode="Markdown"
        )
        
        # Perform operation based on entity type
        if entity_type == "sprint":
            result = self.bot.cli_executor.sprint_start(entity_id)
        else:
            result = self.bot.dispatch_stage(entity_id)
        
        if result.success:
            success_text = get_loading_message(
                "dispatch", 
                "success",
                detail=f"Entity: *{entity_id}*\n\n```{result.stdout}```"
            )
            await query.edit_message_text(
                success_text,
                parse_mode="Markdown"
            )
        else:
            error_text = get_loading_message(
                "dispatch",
                "error",
                detail=f"Entity: *{entity_id}*\n\n```{result.stderr}```"
            )
            await query.edit_message_text(
                error_text,
                parse_mode="Markdown"
            )
    
