#!/bin/bash
#
# Carby Studio CLI - Thin wrapper around team-tasks
# Provides Carby-specific defaults and SDLC stage management
#
# NOTE: Sprint Framework v2.0.0 is now the primary workflow.
# This script delegates sprint commands to carby-sprint for backward compatibility.
#

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Sprint Framework v2.0.0 delegation
# Commands that should be handled by carby-sprint
SPRINT_COMMANDS="init plan start status pause resume cancel archive gate work-item"

# Check if first argument is a sprint command
delegate_to_sprint() {
    local cmd="$1"
    for sprint_cmd in $SPRINT_COMMANDS; do
        if [[ "$cmd" == "$sprint_cmd" ]]; then
            return 0
        fi
    done
    return 1
}

# Show deprecation warning for legacy commands
show_deprecation_warning() {
    local cmd="$1"
    echo -e "\033[1;33m[DEPRECATION WARNING]\033[0m" >&2
    echo -e "The 'carby-studio $cmd' command is deprecated.\n" >&2
    echo -e "Please migrate to the Sprint Framework:\n" >&2
    echo -e "  \033[0;36mcarby-sprint $cmd\033[0m\n" >&2
    echo -e "For more information, see: docs/getting-started.md\n" >&2
}

# Delegate to carby-sprint if available
delegate_sprint_command() {
    if command -v carby-sprint &> /dev/null; then
        carby-sprint "$@"
        exit $?
    else
        echo -e "\033[0;31mError: carby-sprint not found.\033[0m" >&2
        echo -e "Install with: pip install -e /path/to/carby-studio" >&2
        exit 1
    fi
}
# Handle both direct and symlinked execution
if [[ -L "${BASH_SOURCE[0]}" ]]; then
    # Script is symlinked, use real path
    REAL_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
    TEAM_TASKS_DIR="${REAL_DIR}/../team-tasks"
else
    TEAM_TASKS_DIR="${SCRIPT_DIR}/../team-tasks"
fi
TASK_MANAGER="${TEAM_TASKS_DIR}/scripts/task_manager.py"

# Default pipeline for Carby Studio SDLC
CARBY_PIPELINE="discover,design,build,verify,deliver"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Ensure team-tasks is available
if [[ ! -f "$TASK_MANAGER" ]]; then
    echo -e "${RED}Error: team-tasks not found at ${TEAM_TASKS_DIR}${NC}"
    echo "Run: git submodule update --init"
    exit 1
fi

# Set default workspace for Carby projects
export TEAM_TASKS_DIR="${CARBY_WORKSPACE:-$HOME/.openclaw/workspace/projects}"
mkdir -p "$TEAM_TASKS_DIR"

usage() {
    cat << EOF
Carby Studio - AI-native software development studio

╔══════════════════════════════════════════════════════════════════════════════╗
║  DEPRECATED: Legacy Mode                                                     ║
║  Sprint Framework v2.0.0 is now the primary workflow.                        ║
║  Use 'carby-sprint' for new projects.                                        ║
║  See: docs/getting-started.md                                                ║
╚══════════════════════════════════════════════════════════════════════════════╝

Usage: carby-studio <command> [options]

Commands:
  init <project-name>     Initialize a new Carby Studio project (delegates to carby-sprint)
  status <project>        Show project status
  next <project>          Get next stage/agent to dispatch
  update <project> <stage> <status>  Update stage status
  result <project> <stage> <output>  Save stage output
  assign <project> <stage> <task>    Assign task to stage
  ready <project>         Get dispatchable tasks (DAG mode)
  graph <project>         Show dependency graph (DAG mode)
  list                    List all Carby projects
  dispatch <project> <stage>  Spawn agent with retry logic
  credentials <subcommand>  Manage project credentials
    setup                   Initialize credential system
    design <project>        Identify required credentials
    add <project> <type>    Add encrypted credential
    verify <project>        Test all credentials
    migrate <project>       Migrate to production
    audit                   Show all projects status
  metrics                 Show execution metrics dashboard
  check-prerequisites     Verify all dependencies are installed
  validate <project> <stage>  Validate stage output quality
  issue <project> <stage> <title>  Create GitHub issue
  branch <project> <stage>   Create Git branch
  pr <project> <stage>       Create GitHub PR
  deploy <project>           Deploy to configured target
  reset <project> [stage]    Reset stage(s) to pending
  skip <project> <stage>     Skip a stage
  retry <project> <stage>    Reset and retry a stage
  run <project>           Run complete pipeline (interactive)
  watch <project>         Watch for artifacts and auto-advance stages
  validate <project>      Validate project and issue token (V2)
  validate-status <project>  Check validation status (V2)
  validate-check <project>   Check if Design phase access allowed (V2)

Environment:
  CARBY_WORKSPACE         Project storage directory (default: ~/.openclaw/workspace/projects)
  CARBY_AGENT_TIMEOUT     Agent timeout in seconds (default: 3600 = 60 minutes)
                          Recommended: Simple tasks: 1800s (30m)
                                       Complex tasks: 3600s (60m) - DEFAULT
                                       Critical tasks: 7200s (120m)
                          Config file: ~/.openclaw/carby-studio.conf
  CARBY_MODEL_DISCOVER    Model for Discover agent (default: bailian/kimi-k2.5)
  CARBY_MODEL_DESIGN      Model for Design agent (default: bailian/glm-5)
  CARBY_MODEL_BUILD       Model for Build agent (default: bailian/qwen3-coder-plus)
  CARBY_MODEL_VERIFY      Model for Verify agent (default: bailian/qwen3-coder-plus)
  CARBY_MODEL_DELIVER     Model for Deliver agent (default: bailian/kimi-k2.5)

Examples:
  carby-studio init my-api -g "Build REST API for user management"
  carby-studio status my-api
  carby-studio next my-api
  carby-studio update my-api discover done
  carby-studio run my-api

EOF
}

# Initialize a new Carby project with SDLC pipeline
init_project() {
    local project_name="$1"
    local goal=""
    local mode="linear"
    local deploy_target="local-docker"
    
    # Parse args
    shift
    while [[ $# -gt 0 ]]; do
        case $1 in
            -g|--goal)
                goal="$2"
                shift 2
                ;;
            -m|--mode)
                mode="$2"
                shift 2
                ;;
            -d|--deploy)
                deploy_target="$2"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done
    
    if [[ -z "$goal" ]]; then
        echo -e "${YELLOW}Enter project goal:${NC}"
        read -r goal
    fi
    
    # Interactive deploy target selection if not specified
    if [[ "$deploy_target" == "local-docker" && -z "$CARBY_DEPLOY_TARGET" ]]; then
        echo ""
        echo -e "${BLUE}Select deployment target:${NC}"
        echo "  1) local-docker (default - for APIs/services)"
        echo "  2) github-pages (for static sites)"
        echo "  3) fly-io (for production apps)"
        echo "  4) custom (specify later)"
        echo -n "Choice [1-4]: "
        read -r deploy_choice
        
        case "$deploy_choice" in
            2) deploy_target="github-pages" ;;
            3) deploy_target="fly-io" ;;
            4) deploy_target="custom" ;;
            *) deploy_target="local-docker" ;;
        esac
    fi
    
    echo -e "${BLUE}Initializing Carby Studio project: ${project_name}${NC}"
    echo -e "${BLUE}Mode: ${mode}${NC}"
    echo -e "${BLUE}Goal: ${goal}${NC}"
    echo -e "${BLUE}Deploy target: ${deploy_target}${NC}"
    
    # Create project with team-tasks
    python3 "$TASK_MANAGER" init "$project_name" \
        --goal "$goal" \
        --mode "$mode" \
        --pipeline "$CARBY_PIPELINE"
    
    # Create project directory structure
    local project_dir="$TEAM_TASKS_DIR/$project_name"
    mkdir -p "$project_dir"/{docs,src,tests,state,deploy}
    
    # Generate README.md with project info
    local timestamp=$(date '+%Y-%m-%d %H:%M')
    cat > "$project_dir/README.md" << EOF
# ${project_name}

${goal}

## Status
- **Created:** ${timestamp}
- **Mode:** ${mode}
- **Pipeline:** Discover → Design → Build → Verify → Deliver
- **Current Stage:** discover

## Quick Links
- [Requirements](docs/requirements.md) ← Generated by discover agent
- [Design](docs/design.md) ← Generated by design agent

## Project Structure
\`\`\`
${project_name}/
├── docs/          # Documentation
├── src/           # Source code
├── tests/         # Test files
└── deploy/        # Deployment configs
\`\`\`

## Getting Started
<!-- Populated after build phase completes -->

---
*Managed by [Carby Studio](https://github.com/vincentwan939/Carby-Home)*
EOF

    # Generate .gitignore
    cat > "$project_dir/.gitignore" << 'EOF'
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
.venv/
venv/
.env

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Project specific
.carby-local/
*.local
state/
EOF

    # Generate docs/README.md (index)
    cat > "$project_dir/docs/README.md" << EOF
# ${project_name} Documentation

## Documents
- [requirements.md](requirements.md) - Project requirements
- [design.md](design.md) - Architecture and design

## Notes
<!-- Add additional documentation here -->
EOF

    # Copy templates
    local templates_dir="${SCRIPT_DIR}/../templates"
    if [[ -d "$templates_dir" ]]; then
        cp "$templates_dir/requirements.md" "$project_dir/docs/" 2>/dev/null || true
        cp "$templates_dir/design.md" "$project_dir/docs/" 2>/dev/null || true
    fi
    
    # Create deployment config
    create_deploy_config "$project_dir" "$deploy_target"
    
    # Save config
    echo "{\"deploy_target\": \"$deploy_target\", \"project\": \"$project_name\"}" > "$project_dir/.carby-config.json"
    
    # Initialize credential storage structure
    local secrets_dir="$HOME/.openclaw/secrets/projects/$project_name"
    mkdir -p "$secrets_dir"
    echo "# Credentials for $project_name" > "$secrets_dir/README.txt"
    echo "# Use: carby-studio credentials add $project_name <type>" >> "$secrets_dir/README.txt"
    
    echo -e "${GREEN}✓ Project initialized: ${project_name}${NC}"
    echo -e "${GREEN}✓ Location: ${project_dir}${NC}"
    echo -e "${GREEN}✓ Deploy target: ${deploy_target}${NC}"
    echo -e "${GREEN}✓ Credential storage: $secrets_dir${NC}"
    echo ""
    echo "Next steps:"
    echo "  1. carby-studio assign $project_name discover 'Understand requirements'"
    echo "  2. carby-studio credentials design $project_name  # Identify needed credentials"
    echo "  3. carby-studio next $project_name"
}

# Create deployment configuration files
create_deploy_config() {
    local project_dir="$1"
    local target="$2"
    local deploy_dir="$project_dir/deploy"
    
    case "$target" in
        local-docker)
            cat > "$deploy_dir/Dockerfile" << 'EOF'
# Default Dockerfile for Carby Studio projects
FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY src/ ./src/

EXPOSE 8000

CMD ["python", "-m", "src.main"]
EOF
            cat > "$deploy_dir/docker-compose.yml" << 'EOF'
version: '3.8'
services:
  app:
    build: .
    ports:
      - "8000:8000"
    environment:
      - ENV=production
EOF
            ;;
        github-pages)
            cat > "$deploy_dir/.github-workflow.yml" << 'EOF'
name: Deploy to GitHub Pages
on:
  push:
    branches: [ main ]
jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      - name: Deploy
        uses: peaceiris/actions-gh-pages@v3
        with:
          github_token: ${{ secrets.GITHUB_TOKEN }}
          publish_dir: ./dist
EOF
            ;;
        fly-io)
            cat > "$deploy_dir/fly.toml" << 'EOF'
app = "APP_NAME"
primary_region = "sin"

[build]
  dockerfile = "Dockerfile"

[http_service]
  internal_port = 8000
  force_https = true
  auto_stop_machines = true
  auto_start_machines = true
  min_machines_running = 0
EOF
            echo "# Fly.io Deployment
1. Install flyctl: https://fly.io/docs/hands-on/install-flyctl/
2. Run: fly launch
3. Run: fly deploy
" > "$deploy_dir/README.md"
            ;;
    esac
}

# Spawn agent with retry logic and timeout
spawn_agent_with_retry() {
    local project="$1"
    local stage="$2"
    local max_retries="${3:-3}"
    local retry_delay="${4:-5}"
    # Load timeout from config file if exists, else use default
    local config_timeout=""
    if [[ -f "$HOME/.openclaw/carby-studio.conf" ]]; then
        config_timeout=$(grep -E "^CARBY_AGENT_TIMEOUT=" "$HOME/.openclaw/carby-studio.conf" 2>/dev/null | cut -d= -f2 | tr -d '"' | tr -d "'")
    fi
    local timeout_seconds="${CARBY_AGENT_TIMEOUT:-${config_timeout:-3600}}"  # Default 60 minutes
    
    # Special validation for Design stage
    if [[ "$stage" == "design" ]]; then
        echo -e "${BLUE}Checking validation for Design phase...${NC}"
        
        # Check if validation is required and valid
        if ! python3 "${REAL_DIR}/../lib/validation_gate_cli.py" check "$project" >/dev/null 2>&1; then
            echo -e "${RED}✗ Design phase requires validation token${NC}"
            echo -e "${YELLOW}Get validation token:${NC}"
            echo "  carby-studio validate $project"
            echo -e "${YELLOW}Or check current status:${NC}"
            echo "  carby-studio validate-status $project"
            return 1
        fi
        
        echo -e "${GREEN}✓ Design phase validation passed${NC}"
    fi
    
    # Get model for stage
    local model=""
    case "$stage" in
        discover) model="${CARBY_MODEL_DISCOVER:-bailian/kimi-k2.5}" ;;
        design) model="${CARBY_MODEL_DESIGN:-bailian/glm-5}" ;;
        build) model="${CARBY_MODEL_BUILD:-bailian/qwen3-coder-plus}" ;;
        verify) model="${CARBY_MODEL_VERIFY:-bailian/qwen3-coder-plus}" ;;
        deliver) model="${CARBY_MODEL_DELIVER:-bailian/kimi-k2.5}" ;;
    esac
    
    local attempt=1
    while [[ $attempt -le $max_retries ]]; do
        echo -e "${BLUE}Spawning ${stage} agent (attempt ${attempt}/${max_retries}, timeout: ${timeout_seconds}s)...${NC}"
        
        # Update status to in-progress before spawning
        python3 "$TASK_MANAGER" update "$project" "$stage" in-progress 2>/dev/null || true
        python3 "$TASK_MANAGER" log "$project" "$stage" "Agent spawn attempt ${attempt}/${max_retries}" 2>/dev/null || true
        
        # Spawn the agent with timeout (macOS compatible)
        local exit_code=0
        # Ensure openclaw is in PATH
        export PATH="/opt/homebrew/bin:$PATH"
        
        # Use gtimeout if available (brew install coreutils), otherwise no timeout
        local agent_id="main"
        if command -v gtimeout >/dev/null 2>&1; then
            gtimeout "$timeout_seconds" /opt/homebrew/bin/openclaw agent \
                --local \
                --agent "$agent_id" \
                --message "Execute Carby Studio ${stage} phase for ${project}. Work in directory: ${TEAM_TASKS_DIR}/${project}" \
                --thinking medium \
                2>/dev/null || exit_code=$?
        elif command -v timeout >/dev/null 2>&1; then
            timeout "$timeout_seconds" /opt/homebrew/bin/openclaw agent \
                --local \
                --agent "$agent_id" \
                --message "Execute Carby Studio ${stage} phase for ${project}. Work in directory: ${TEAM_TASKS_DIR}/${project}" \
                --thinking medium \
                2>/dev/null || exit_code=$?
        else
            # No timeout available, run directly
            /opt/homebrew/bin/openclaw agent \
                --local \
                --agent "$agent_id" \
                --message "Execute Carby Studio ${stage} phase for ${project}. Work in directory: ${TEAM_TASKS_DIR}/${project}" \
                --thinking medium \
                2>/dev/null || exit_code=$?
        fi
        
        # Check exit code
        if [[ $exit_code -eq 0 ]]; then
            echo -e "${GREEN}✓ Agent completed successfully${NC}"
            python3 "$TASK_MANAGER" log "$project" "$stage" "Agent completed" 2>/dev/null || true
            return 0
        elif [[ $exit_code -eq 124 ]]; then
            echo -e "${RED}✗ Agent timed out after ${timeout_seconds}s${NC}"
            python3 "$TASK_MANAGER" log "$project" "$stage" "TIMEOUT after ${timeout_seconds}s" 2>/dev/null || true
        else
            echo -e "${RED}✗ Spawn failed (attempt ${attempt}, exit: ${exit_code})${NC}"
            python3 "$TASK_MANAGER" log "$project" "$stage" "Spawn failed: exit ${exit_code}" 2>/dev/null || true
        fi
        
        if [[ $attempt -lt $max_retries ]]; then
            echo -e "${BLUE}  Retrying in ${retry_delay} seconds...${NC}"
            sleep "$retry_delay"
        fi
        
        ((attempt++))
    done
    
    echo -e "${RED}✗ Failed to complete agent after ${max_retries} attempts${NC}"
    # Mark as failed
    python3 "$TASK_MANAGER" update "$project" "$stage" failed 2>/dev/null || true
    python3 "$TASK_MANAGER" log "$project" "$stage" "FAILED after ${max_retries} attempts" 2>/dev/null || true
    return 1
}

# Get next stage with Carby-specific context
get_next() {
    local project="$1"
    local next_stage
    next_stage=$(python3 "$TASK_MANAGER" next "$project" 2>/dev/null | grep "Next stage:" | cut -d: -f2 | xargs)
    
    if [[ -n "$next_stage" ]]; then
        # Get model for stage (bash 3.2 compatible)
        local model=""
        case "$next_stage" in
            discover) model="${CARBY_MODEL_DISCOVER:-bailian/kimi-k2.5}" ;;
            design) model="${CARBY_MODEL_DESIGN:-bailian/glm-5}" ;;
            build) model="${CARBY_MODEL_BUILD:-bailian/qwen3-coder-plus}" ;;
            verify) model="${CARBY_MODEL_VERIFY:-bailian/qwen3-coder-plus}" ;;
            deliver) model="${CARBY_MODEL_DELIVER:-bailian/kimi-k2.5}" ;;
        esac
        
        echo -e "${GREEN}Next stage: ${next_stage}${NC}"
        echo -e "${BLUE}   Model: ${model}${NC}"
        echo ""
        echo "Manual dispatch:"
        echo "  openclaw sessions_spawn --runtime subagent --mode run \\"
        echo "    --model ${model} \\"
        echo "    --task \"Execute Carby Studio ${next_stage} phase for ${project}\""
        echo ""
        echo "Or use auto-dispatch:"
        echo "  carby-studio dispatch ${project} ${next_stage}"
    else
        python3 "$TASK_MANAGER" next "$project"
    fi
}

# Run complete pipeline interactively
run_pipeline() {
    local project="$1"
    
    echo -e "${BLUE}Running Carby Studio pipeline for: ${project}${NC}"
    echo ""
    
    while true; do
        # Show current status
        python3 "$TASK_MANAGER" status "$project"
        echo ""
        
        # Get next stage
        local next_stage
        next_stage=$(python3 "$TASK_MANAGER" next "$project" 2>/dev/null | grep "Next stage:" | cut -d: -f2 | xargs)
        
        if [[ -z "$next_stage" ]]; then
            echo -e "${GREEN}🎉 Pipeline complete!${NC}"
            break
        fi
        
        echo -e "${YELLOW}Next: ${next_stage}${NC}"
        echo "Options: (d)ispatch (s)kip (u)pdate status (q)uit"
        read -r -n 1 choice
        echo ""
        
        case $choice in
            d|D)
                echo "Dispatching ${next_stage} agent..."
                local model=""
                case "$next_stage" in
                    discover) model="${CARBY_MODEL_DISCOVER:-bailian/kimi-k2.5}" ;;
                    design) model="${CARBY_MODEL_DESIGN:-bailian/glm-5}" ;;
                    build) model="${CARBY_MODEL_BUILD:-bailian/qwen3-coder-plus}" ;;
                    verify) model="${CARBY_MODEL_VERIFY:-bailian/qwen3-coder-plus}" ;;
                    deliver) model="${CARBY_MODEL_DELIVER:-bailian/kimi-k2.5}" ;;
                esac
                echo "Model: ${model}"
                ;;
            s|S)
                echo "Skipping ${next_stage}..."
                python3 "$TASK_MANAGER" update "$project" "$next_stage" skipped
                ;;
            u|U)
                echo "Enter status (pending/in-progress/done/failed):"
                read -r status
                python3 "$TASK_MANAGER" update "$project" "$next_stage" "$status"
                ;;
            q|Q)
                echo "Exiting pipeline. Resume with: carby-studio run $project"
                break
                ;;
        esac
        echo ""
    done
}

# Get artifact path for a stage (macOS bash 3.2 compatible)
get_artifact_for_stage() {
    local stage="$1"
    case "$stage" in
        discover) echo "docs/requirements.md" ;;
        design) echo "docs/design.md" ;;
        build) echo "src/" ;;
        verify) echo "docs/verify-report.md" ;;
        deliver) echo "docs/delivery-summary.md" ;;
        *) echo "" ;;
    esac
}

# Check if artifact exists for a stage
check_artifact_exists() {
    local project_dir="$1"
    local stage="$2"
    local artifact
    artifact=$(get_artifact_for_stage "$stage")
    
    if [[ -z "$artifact" ]]; then
        return 1
    fi
    
    local full_path="${project_dir}/${artifact}"
    
    if [[ "$artifact" == */ ]]; then
        # Directory artifact (like src/)
        [[ -d "$full_path" ]] && [[ -n "$(ls -A "$full_path" 2>/dev/null)" ]]
    else
        # File artifact
        [[ -f "$full_path" ]]
    fi
}

# Watch for file changes and auto-advance stages
watch_project() {
    local project="$1"
    local interval="${2:-5}"
    
    echo -e "${BLUE}Watching project: ${project}${NC}"
    echo -e "${BLUE}   Checking every ${interval} seconds${NC}"
    echo -e "${BLUE}   Press Ctrl+C to stop${NC}"
    echo ""
    
    local project_dir
    project_dir="${TEAM_TASKS_DIR}/${project}"
    
    while true; do
        # Get current stage
        local current_stage
        current_stage=$(python3 "$TASK_MANAGER" next "$project" 2>/dev/null | grep "Next stage:" | cut -d: -f2 | xargs)
        
        if [[ -z "$current_stage" ]]; then
            echo -e "${GREEN}Pipeline complete!${NC}"
            break
        fi
        
        # Check if artifact exists for current stage
        local artifact
        artifact=$(get_artifact_for_stage "$current_stage")
        
        if [[ -n "$artifact" ]]; then
            local full_path="${project_dir}/${artifact}"
            
            if [[ -e "$full_path" ]]; then
                echo -e "${GREEN}Detected artifact: ${artifact}${NC}"
                echo -e "${BLUE}   Auto-advancing stage: ${current_stage}${NC}"
                
                # Mark stage as done
                python3 "$TASK_MANAGER" update "$project" "$current_stage" done
                
                # Show next stage
                local next_stage
                next_stage=$(python3 "$TASK_MANAGER" next "$project" 2>/dev/null | grep "Next stage:" | cut -d: -f2 | xargs)
                if [[ -n "$next_stage" ]]; then
                    echo -e "${GREEN}Next stage: ${next_stage}${NC}"
                fi
                echo ""
            fi
        fi
        
        sleep "$interval"
    done
}

# Sprint Framework v2.0.0 delegation check
# If the command is a sprint command, delegate to carby-sprint
if delegate_to_sprint "${1:-}"; then
    show_deprecation_warning "${1:-}"
    delegate_sprint_command "$@"
fi

# Main command dispatcher
case "${1:-}" in
    init)
        shift
        if [[ $# -eq 0 ]]; then
            echo -e "${RED}Error: Project name required${NC}"
            usage
            exit 1
        fi
        init_project "$@"
        ;;
    status)
        shift
        python3 "$TASK_MANAGER" status "$@"
        ;;
    next)
        shift
        get_next "$@"
        ;;
    update)
        shift
        project="$1"
        stage="$2"
        status="$3"
        
        # Check if --force was passed anywhere in args
        force_mode=false
        for arg in "$@"; do
            if [[ "$arg" == "--force" ]]; then
                force_mode=true
                break
            fi
        done
        
        # If marking as done, check artifact exists and validate (unless --force)
        if [[ "$status" == "done" && "$force_mode" != true ]]; then
            project_dir="${TEAM_TASKS_DIR}/${project}"
            
            # Check artifact exists
            if ! check_artifact_exists "$project_dir" "$stage"; then
                echo -e "${RED}✗ Cannot mark ${stage} as done: artifact not found${NC}"
                echo -e "${YELLOW}Expected: $(get_artifact_for_stage "$stage")${NC}"
                echo -e "${YELLOW}Use --force to override:${NC}"
                echo "  carby-studio update ${project} ${stage} done --force"
                exit 1
            fi
            
            # Run validator
            validator="${SCRIPT_DIR}/validator.py"
            if [[ -f "$validator" ]]; then
                echo -e "${BLUE}Validating ${stage} before marking done...${NC}"
                if ! python3 "$validator" "$project_dir" "$stage" --json > /dev/null 2>&1; then
                    echo -e "${RED}✗ Validation failed for ${stage}${NC}"
                    echo -e "${YELLOW}Run validation to see errors:${NC}"
                    echo "  carby-studio validate ${project} ${stage}"
                    echo -e "${YELLOW}Or use --force to override:${NC}"
                    echo "  carby-studio update ${project} ${stage} done --force"
                    exit 1
                fi
                echo -e "${GREEN}✓ Validation passed${NC}"
            fi
        fi
        
        # Remove --force from args before passing to task_manager
        tm_args=()
        for arg in "$@"; do
            if [[ "$arg" != "--force" ]]; then
                tm_args+=("$arg")
            fi
        done
        
        python3 "$TASK_MANAGER" update "${tm_args[@]}"
        ;;
    result)
        shift
        python3 "$TASK_MANAGER" result "$@"
        ;;
    assign)
        shift
        python3 "$TASK_MANAGER" assign "$@"
        ;;
    ready)
        shift
        python3 "$TASK_MANAGER" ready "$@"
        ;;
    graph)
        shift
        python3 "$TASK_MANAGER" graph "$@"
        ;;
    list)
        python3 "$TASK_MANAGER" list
        ;;
    dispatch)
        shift
        if [[ $# -lt 2 ]]; then
            echo -e "${RED}Error: Project name and stage required${NC}"
            echo "Usage: carby-studio dispatch <project> <stage>"
            exit 1
        fi
        spawn_agent_with_retry "$1" "$2"
        ;;
    run)
        shift
        if [[ $# -eq 0 ]]; then
            echo -e "${RED}Error: Project name required${NC}"
            exit 1
        fi
        run_pipeline "$1"
        ;;
    watch)
        shift
        if [[ $# -eq 0 ]]; then
            echo -e "${RED}Error: Project name required${NC}"
            exit 1
        fi
        watch_project "$1"
        ;;
    validate)
        shift
        if [[ $# -eq 0 ]]; then
            echo -e "${RED}Error: Project name required${NC}"
            echo "Usage: carby-studio validate <project> [--tier tier1|tier2|tier3]"
            exit 1
        fi
        project="$1"
        tier_arg=""
        
        # Parse optional tier
        while [[ $# -gt 0 ]]; do
            case $1 in
                --tier)
                    tier_arg="--tier $2"
                    shift 2
                    ;;
                *)
                    shift
                    ;;
            esac
        done
        
        # Use Python validation gate
        python3 "${REAL_DIR}/../lib/validation_gate_cli.py" validate "$project" $tier_arg
        ;;
    validate-status)
        shift
        if [[ $# -eq 0 ]]; then
            echo -e "${RED}Error: Project name required${NC}"
            echo "Usage: carby-studio validate-status <project>"
            exit 1
        fi
        python3 "${REAL_DIR}/../lib/validation_gate_cli.py" status "$1"
        ;;
    validate-check)
        shift
        if [[ $# -eq 0 ]]; then
            echo -e "${RED}Error: Project name required${NC}"
            echo "Usage: carby-studio validate-check <project> [--token TOKEN]"
            exit 1
        fi
        project="$1"
        token_arg=""
        
        # Parse optional token
        while [[ $# -gt 0 ]]; do
            case $1 in
                --token)
                    token_arg="--token $2"
                    shift 2
                    ;;
                *)
                    shift
                    ;;
            esac
        done
        
        python3 "${REAL_DIR}/../lib/validation_gate_cli.py" check "$project" $token_arg
        ;;
    validate)
        shift
        if [[ $# -lt 2 ]]; then
            echo -e "${RED}Error: Project name and stage required${NC}"
            echo "Usage: carby-studio validate <project> <stage>"
            exit 1
        fi
        project="$1"
        stage="$2"
        project_dir="${TEAM_TASKS_DIR}/${project}"
        validator="${SCRIPT_DIR}/validator.py"
        
        if [[ ! -f "$validator" ]]; then
            echo -e "${RED}Error: validator.py not found${NC}"
            exit 1
        fi
        
        echo -e "${BLUE}Validating ${stage} output for ${project}...${NC}"
        if python3 "$validator" "$project_dir" "$stage"; then
            echo -e "${GREEN}✓ Validation passed${NC}"
            exit 0
        else
            echo -e "${RED}✗ Validation failed${NC}"
            exit 1
        fi
        ;;
    issue)
        shift
        if [[ $# -lt 3 ]]; then
            echo -e "${RED}Error: Project, stage, and title required${NC}"
            echo "Usage: carby-studio issue <project> <stage> <title> [--body <body>]"
            exit 1
        fi
        project="$1"
        stage="$2"
        title="$3"
        body=""
        
        # Parse optional body
        while [[ $# -gt 0 ]]; do
            case $1 in
                --body)
                    body="$2"
                    shift 2
                    ;;
                *)
                    shift
                    ;;
            esac
        done
        
        project_dir="${TEAM_TASKS_DIR}/${project}"
        
        # Create issue using gh CLI
        if [[ -n "$body" ]]; then
            gh issue create --title "[${stage}] ${title}" --body "$body" 2>/dev/null || echo "Note: Labels not created (may need to add them in GitHub)"
        else
            gh issue create --title "[${stage}] ${title}" 2>/dev/null || echo "Note: Labels not created (may need to add them in GitHub)"
        fi
        ;;
    branch)
        shift
        if [[ $# -lt 2 ]]; then
            echo -e "${RED}Error: Project and stage required${NC}"
            echo "Usage: carby-studio branch <project> <stage> [--issue <issue-number>]"
            exit 1
        fi
        project="$1"
        stage="$2"
        issue_num=""
        
        # Parse optional issue
        while [[ $# -gt 0 ]]; do
            case $1 in
                --issue)
                    issue_num="$2"
                    shift 2
                    ;;
                *)
                    shift
                    ;;
            esac
        done
        
        project_dir="${TEAM_TASKS_DIR}/${project}"
        branch_name="carby/${stage}/$(date +%Y%m%d-%H%M%S)"
        
        cd "$project_dir" || exit 1
        
        # Create and checkout branch
        git checkout -b "$branch_name" || exit 1
        
        echo -e "${GREEN}✓ Created branch: ${branch_name}${NC}"
        
        # Link to issue if provided
        if [[ -n "$issue_num" ]]; then
            git commit --allow-empty -m "Start ${stage} phase

Refs #${issue_num}"
            echo -e "${BLUE}Linked to issue #${issue_num}${NC}"
        fi
        ;;
    pr)
        shift
        if [[ $# -lt 2 ]]; then
            echo -e "${RED}Error: Project and stage required${NC}"
            echo "Usage: carby-studio pr <project> <stage> [--title <title>] [--body <body>]"
            exit 1
        fi
        project="$1"
        stage="$2"
        title=""
        body=""
        
        # Parse optional args
        while [[ $# -gt 0 ]]; do
            case $1 in
                --title)
                    title="$2"
                    shift 2
                    ;;
                --body)
                    body="$2"
                    shift 2
                    ;;
                *)
                    shift
                    ;;
            esac
        done
        
        project_dir="${TEAM_TASKS_DIR}/${project}"
        
        # Default title/body
        if [[ -z "$title" ]]; then
            title="[${stage}] Implementation complete"
        fi
        if [[ -z "$body" ]]; then
            body="## Summary\nImplementation for ${stage} phase.\n\n## Changes\n- [Describe changes]\n\n## Testing\n- [ ] Tests pass\n- [ ] Manual verification"
        fi
        
        cd "$project_dir" || exit 1
        
        # Push current branch
        git push -u origin HEAD || echo "Failed to push"
        
        # Create PR
        gh pr create --title "$title" --body "$body" 2>/dev/null || echo "Note: PR creation may require pushing to GitHub first"
        ;;
    deploy)
        shift
        if [[ $# -eq 0 ]]; then
            echo -e "${RED}Error: Project name required${NC}"
            echo "Usage: carby-studio deploy <project>"
            exit 1
        fi
        project="$1"
        project_dir="${TEAM_TASKS_DIR}/${project}"
        
        # Check credential status before deploy
        echo -e "${BLUE}Checking credentials...${NC}"
        local metadata_file="$HOME/.openclaw/secrets/projects/$project/metadata.yaml"
        if [[ -f "$metadata_file" ]]; then
            local env_status=$(python3 -c "import yaml; print(yaml.safe_load(open('$metadata_file')).get('environment','dev'))" 2>/dev/null || echo "dev")
            if [[ "$env_status" != "prod" ]]; then
                echo -e "${RED}✗ DEPLOYMENT BLOCKED${NC}"
                echo ""
                echo "Credentials not migrated to production."
                echo "Current environment: $env_status"
                echo ""
                echo "To migrate:"
                echo "  carby-studio credentials migrate $project --to keychain"
                echo ""
                exit 1
            fi
            echo -e "${GREEN}✓ Credentials verified (production)${NC}"
        else
            echo -e "${YELLOW}⚠ No credentials configured${NC}"
        fi
        
        # Read deploy target from config
        if [[ -f "$project_dir/.carby-config.json" ]]; then
            deploy_target=$(cat "$project_dir/.carby-config.json" | python3 -c "import sys,json; print(json.load(sys.stdin).get('deploy_target','local-docker'))")
        else
            deploy_target="local-docker"
        fi
        
        echo -e "${BLUE}Deploying ${project} to ${deploy_target}...${NC}"
        
        cd "$project_dir" || exit 1
        
        case "$deploy_target" in
            local-docker)
                if [[ -f "deploy/docker-compose.yml" ]]; then
                    docker-compose -f deploy/docker-compose.yml up --build -d
                    echo -e "${GREEN}✓ Deployed to local Docker${NC}"
                    echo "  URL: http://localhost:8000"
                else
                    echo -e "${RED}✗ docker-compose.yml not found${NC}"
                    exit 1
                fi
                ;;
            github-pages)
                echo -e "${YELLOW}GitHub Pages deployment:${NC}"
                echo "  1. Ensure dist/ folder has built files"
                echo "  2. Push to main branch"
                echo "  3. GitHub Actions will deploy automatically"
                ;;
            fly-io)
                if command -v flyctl &> /dev/null; then
                    fly deploy
                    echo -e "${GREEN}✓ Deployed to Fly.io${NC}"
                else
                    echo -e "${RED}✗ flyctl not installed${NC}"
                    echo "  Install: https://fly.io/docs/hands-on/install-flyctl/"
                    exit 1
                fi
                ;;
            custom)
                echo -e "${YELLOW}Custom deployment target${NC}"
                echo "  Add your deployment commands to deploy/custom.sh"
                if [[ -f "deploy/custom.sh" ]]; then
                    bash deploy/custom.sh
                else
                    echo "  deploy/custom.sh not found"
                fi
                ;;
            *)
                echo -e "${RED}Unknown deploy target: ${deploy_target}${NC}"
                exit 1
                ;;
        esac
        ;;
    reset)
        shift
        if [[ $# -eq 0 ]]; then
            echo -e "${RED}Error: Project name required${NC}"
            echo "Usage: carby-studio reset <project> [stage]"
            exit 1
        fi
        project="$1"
        stage="${2:-}"
        
        if [[ -n "$stage" ]]; then
            echo -e "${BLUE}Resetting ${stage} to pending...${NC}"
            python3 "$TASK_MANAGER" reset "$project" "$stage"
        else
            echo -e "${BLUE}Resetting all stages to pending...${NC}"
            python3 "$TASK_MANAGER" reset "$project"
        fi
        echo -e "${GREEN}✓ Reset complete${NC}"
        ;;
    skip)
        shift
        if [[ $# -lt 2 ]]; then
            echo -e "${RED}Error: Project and stage required${NC}"
            echo "Usage: carby-studio skip <project> <stage>"
            exit 1
        fi
        project="$1"
        stage="$2"
        
        echo -e "${YELLOW}Skipping ${stage}...${NC}"
        python3 "$TASK_MANAGER" update "$project" "$stage" skipped
        echo -e "${GREEN}✓ ${stage} marked as skipped${NC}"
        ;;
    retry)
        shift
        if [[ $# -lt 2 ]]; then
            echo -e "${RED}Error: Project and stage required${NC}"
            echo "Usage: carby-studio retry <project> <stage>"
            exit 1
        fi
        project="$1"
        stage="$2"
        
        echo -e "${BLUE}Retrying ${stage}...${NC}"
        python3 "$TASK_MANAGER" reset "$project" "$stage"
        echo -e "${GREEN}✓ ${stage} reset to pending${NC}"
        echo ""
        echo "To retry the stage, run:"
        echo "  carby-studio dispatch ${project} ${stage}"
        ;;
    metrics)
        shift
        python3 "${SCRIPT_DIR}/metrics.py" --dashboard "$@"
        ;;
    check-prerequisites)
        "${SCRIPT_DIR}/check-prerequisites.sh"
        ;;
    credentials)
        shift
        if [[ $# -eq 0 ]]; then
            echo -e "${BLUE}Carby Studio Credential Management${NC}"
            echo ""
            echo "Usage: carby-studio credentials <command> [args]"
            echo ""
            echo "Commands:"
            echo "  list <project>              List credentials for a project"
            echo "  get <project> <type> <name> Get credential value"
            echo "  add <project> <type> <name> Add new credential"
            echo "  verify <project>            Verify all credentials"
            echo "  status <project>            Show credential status"
            echo "  audit                       Audit all projects"
            echo "  migrate <project>           Migrate project to Bitwarden"
            echo "  unlock                      Unlock Bitwarden session"
            echo "  lock                        Lock Bitwarden session"
            echo ""
            echo "Credential Types: nas, icloud, google-api, database, api-key"
            echo ""
            echo "Examples:"
            echo "  carby-studio credentials list family-photo-hub"
            echo "  carby-studio credentials add family-photo-hub nas synology --field host=192.168.1.100 --field username=admin"
            echo "  carby-studio credentials migrate family-photo-hub"
            exit 0
        fi
        
        CREDENTIALS_HANDLER="${REAL_DIR}/../lib/credentials_handler.py"
        SESSION_MANAGER="${REAL_DIR}/../lib/session_manager.py"
        
        case "${1:-}" in
            list)
                if [[ $# -lt 2 ]]; then
                    echo -e "${RED}Error: Project name required${NC}"
                    exit 1
                fi
                python3 "$CREDENTIALS_HANDLER" list "${2}"
                ;;
            get)
                if [[ $# -lt 4 ]]; then
                    echo -e "${RED}Error: project, type, and name required${NC}"
                    exit 1
                fi
                python3 "$CREDENTIALS_HANDLER" get "${2}" "${3}" "${4}"
                ;;
            add)
                if [[ $# -lt 4 ]]; then
                    echo -e "${RED}Error: project, type, and name required${NC}"
                    exit 1
                fi
                shift
                python3 "$CREDENTIALS_HANDLER" add "$@"
                ;;
            verify)
                if [[ $# -lt 2 ]]; then
                    echo -e "${RED}Error: Project name required${NC}"
                    exit 1
                fi
                python3 "$CREDENTIALS_HANDLER" verify "${2}"
                ;;
            status)
                if [[ $# -lt 2 ]]; then
                    echo -e "${RED}Error: Project name required${NC}"
                    exit 1
                fi
                python3 "$CREDENTIALS_HANDLER" status "${2}"
                ;;
            audit)
                python3 "$CREDENTIALS_HANDLER" audit
                ;;
            migrate)
                if [[ $# -lt 2 ]]; then
                    echo -e "${RED}Error: Project name required${NC}"
                    exit 1
                fi
                "${REAL_DIR}/migrate-to-bitwarden.sh" "${2}"
                ;;
            unlock)
                python3 "$SESSION_MANAGER" unlock
                ;;
            lock)
                python3 "$SESSION_MANAGER" lock
                ;;
            *)
                echo -e "${RED}Unknown credentials command: ${1}${NC}"
                echo "Run 'carby-studio credentials' for usage"
                exit 1
                ;;
        esac
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        echo -e "${RED}Unknown command: ${1:-}${NC}"
        usage
        exit 1
        ;;
esac
